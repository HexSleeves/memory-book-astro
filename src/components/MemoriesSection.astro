---
import { getCollection } from "astro:content";
import MemoryCard from "./MemoryCard.astro";

const memories = (await getCollection("memories")).sort((a, b) => a.data.order - b.data.order);
---

<section id="memories" class="memories" aria-labelledby="memories-title">
  <div class="container">
    <header class="header" data-reveal>
      <p class="kicker">Section two</p>
      <h2 id="memories-title" class="title">Favorite memories</h2>
    </header>
    {memories.map((memory, i) => <MemoryCard memory={memory} index={i} />)}
  </div>
</section>

<style>
  .memories {
    padding-block: var(--space-16);
  }

  .header {
    text-align: center;
    margin-bottom: var(--space-8);
    max-width: 36rem;
    margin-inline: auto;
  }

  .kicker {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.78rem;
    color: var(--ink-faded);
    margin: 0 0 var(--space-3);
  }

  .title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-2xl);
    line-height: var(--leading-tight);
    color: var(--ink-deep);
    margin: 0;
  }

  @media (min-width: 40rem) {
    .memories { padding-block: var(--space-24); }
    .title { font-size: var(--text-3xl); }
  }
</style>
