---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";

const cover = await getEntry("cover", "cover");
if (!cover) throw new Error("Missing cover content");

const { title, dedication, photo, photoTilt } = cover.data;
---

<section class="cover" aria-label="Cover">
  <div class="cover-inner">
    {
      photo && (
        <figure class="cover-photo polaroid taped" style={`--polaroid-tilt:${photoTilt}deg`}>
          <Image src={photo} alt="" widths={[480, 800, 1200]} sizes="(max-width: 640px) 80vw, 480px" />
          <figcaption class="sr-only">Cover photograph</figcaption>
        </figure>
      )
    }
    <h1 class="cover-title">
      {title.split("").map((ch, i) => <span class="ch" style={`--i:${i}`}>{ch === " " ? " " : ch}</span>)}
    </h1>
    <p class="dedication">{dedication}</p>
    <a class="begin" href="#lessons" aria-label="Begin reading">
      <span>begin</span>
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path
          d="M6 9l6 6 6-6"
          fill="none"
          stroke="currentColor"
          stroke-width="2.4"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>
</section>

<style>
  .cover {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: var(--space-12) var(--space-4);
    text-align: center;
  }

  .cover-inner {
    display: grid;
    gap: var(--space-8);
    justify-items: center;
    max-width: 32rem;
  }

  .cover-photo {
    --polaroid-tilt: -3deg;
    max-width: 18rem;
    margin: 0;
  }
  .cover-photo :global(img) {
    width: 100%;
    height: auto;
    aspect-ratio: 4/5;
    object-fit: cover;
  }

  .cover-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
    color: var(--ink-deep);
    margin: 0;
    font-weight: 400;
  }
  .cover-title .ch {
    display: inline-block;
    opacity: 0;
    transform: translateY(0.4em);
    animation: ch-rise 600ms var(--ease-paper) forwards;
    animation-delay: calc(var(--i) * 60ms + 200ms);
  }

  @keyframes ch-rise {
    to {
      opacity: 1;
      transform: none;
    }
  }

  .dedication {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--ink-soft);
    margin: 0;
    max-width: 28rem;
    line-height: 1.5;
  }

  .begin {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    text-transform: lowercase;
    letter-spacing: 0.15em;
    color: var(--ink-soft);
    text-decoration: none;
    padding: var(--space-3) var(--space-6);
    border: 1.5px solid var(--ink-faded);
    border-radius: 999px;
    margin-top: var(--space-4);
  }
  .begin svg {
    animation: bob 1.6s var(--ease-paper) infinite;
  }
  .begin:hover svg {
    animation-play-state: paused;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(3px); }
  }

  @media (min-width: 40rem) {
    .cover-title { font-size: var(--text-4xl); }
    .cover-photo { max-width: 22rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cover-title .ch {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .begin svg { animation: none; }
  }
</style>
