---
import { getCollection } from "astro:content";
import LessonCard from "./LessonCard.astro";

const lessons = (await getCollection("lessons")).sort((a, b) => a.data.order - b.data.order);
---

<section id="lessons" class="lessons" aria-labelledby="lessons-title">
  <div class="container">
    <header class="header" data-reveal>
      <p class="kicker">Section one</p>
      <h2 id="lessons-title" class="title">Things I learned from you</h2>
    </header>
    <div class="grid">
      {lessons.map((lesson, i) => <LessonCard lesson={lesson} index={i} />)}
    </div>
  </div>
</section>

<style>
  .lessons {
    padding-block: var(--space-16);
  }

  .header {
    text-align: center;
    margin-bottom: var(--space-12);
    max-width: 36rem;
    margin-inline: auto;
  }

  .kicker {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.78rem;
    color: var(--ink-faded);
    margin: 0 0 var(--space-3);
  }

  .title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-2xl);
    line-height: var(--leading-tight);
    color: var(--ink-deep);
    margin: 0;
  }

  .grid {
    display: grid;
    gap: var(--space-6);
    max-width: 48rem;
    margin-inline: auto;
  }

  @media (min-width: 40rem) {
    .lessons { padding-block: var(--space-24); }
    .title { font-size: var(--text-3xl); }
    .grid { gap: var(--space-8); }
  }
</style>
