---
interface Props {
  variant?: "tape" | "doodle" | "stars";
}

const { variant = "tape" } = Astro.props;
---

<div class="divider" aria-hidden="true" data-reveal="fade">
  {
    variant === "tape" && (
      <svg viewBox="0 0 200 40" preserveAspectRatio="none">
        <rect
          x="20"
          y="12"
          width="160"
          height="16"
          fill="var(--tape-yellow)"
          opacity="0.78"
          transform="rotate(-1.5 100 20)"
        />
      </svg>
    )
  }
  {
    variant === "doodle" && (
      <svg viewBox="0 0 220 40" preserveAspectRatio="none">
        <path
          d="M10 24 Q 40 8, 70 22 T 130 22 T 190 22 T 210 18"
          fill="none"
          stroke="var(--doodle-rust)"
          stroke-width="2.4"
          stroke-linecap="round"
        />
      </svg>
    )
  }
  {
    variant === "stars" && (
      <svg viewBox="0 0 220 40" preserveAspectRatio="none">
        <g fill="var(--doodle-sage)" stroke="var(--doodle-sage)" stroke-linecap="round">
          <circle cx="60" cy="20" r="2.5" />
          <circle cx="110" cy="20" r="3.5" />
          <circle cx="160" cy="20" r="2.5" />
        </g>
      </svg>
    )
  }
</div>

<style>
  .divider {
    width: 100%;
    max-width: 24rem;
    height: 40px;
    margin: var(--space-16) auto;
  }
  svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  @media (min-width: 64rem) {
    .divider {
      margin: var(--space-24) auto;
    }
  }
</style>
